<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tic Tac Toe" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tic Tac Toe">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Add Materialize CSS CDN link to the head section -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <style>
      body {
        background: #222 !important;
        color: #eee !important;
      }
      .container {
        background: #2c2c2c;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        padding: 32px;
      }
      table.striped.centered {
        background: #333;
      }
      td {
        background: #444 !important;
        color: #fff !important;
        border: 1px solid #555 !important;
      }
      .cell-link {
        min-width: 40px;
        min-height: 40px;
        display: block;
        width: 100%;
        height: 100%;
        background: #80cbc4 !important;
        margin: 0;
        padding: 0;
        border-radius: 4px;
        transition: background 0.2s;
      }
      .cell-link:hover {
        background: #4fb3bf !important;
      }
      .teal-text, .btn-large.teal {
        color: #80cbc4 !important;
        background: #263238 !important;
      }
      .btn-large.red {
        background: #b71c1c !important;
      }
      .badge.teal {
        background: #009688 !important;
      }
      .badge.grey {
        background: #555 !important;
      }
    </style>
  </head>

  <body>
    <%= yield %>
    <!-- Add Materialize JS CDN link before closing body tag -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
  </body>
</html>
