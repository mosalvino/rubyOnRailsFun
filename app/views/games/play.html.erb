<div class="container center-align" style="margin-top: 40px;">
  <h1 class="teal-text">Play Tic Tac Toe</h1>
  <table class="striped centered" style="margin: 0 auto;">
    <% mode = params[:mode] || 'friend' %>
    <% player = params[:player] || 'X' %>
    <% @game.board_array.each_with_index do |row, i| %>
      <tr>
        <% row.each_with_index do |cell, j| %>
          <td style="width:40px;height:40px;text-align:center;border:1px solid #000; padding:0;">
            <% pos = i*3 + j %>
            <% if cell == '-' && @game.status == 'ongoing' %>
              <% if mode == 'friend' %>
                <%= link_to '', games_play_path(position: pos, mode: mode, player: player), class: 'cell-link', style: 'display:block;width:100%;height:100%;background:#eee;' %>
              <% else %>
                <%= link_to '', games_play_path(position: pos, mode: mode), class: 'cell-link', style: 'display:block;width:100%;height:100%;background:#eee;' %>
              <% end %>
            <% else %>
              <%= cell %>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </table>
  <p class="flow-text">Current Player: <span class="badge teal white-text"> <%= @game.current_player %> </span></p>
  <p class="flow-text">Status: <span class="badge grey lighten-1 white-text"> <%= @game.status %> </span></p>
  <div style="margin-top: 20px;">
    <%= link_to 'Back to Start', games_start_path, class: 'btn-large teal lighten-1' %>
    <%= link_to 'Reset', games_reset_path, class: 'btn-large red lighten-1' %>
    <% if mode == 'friend' %>
      <%= link_to 'Play vs CPU', games_play_path(mode: 'single'), class: 'btn-large blue lighten-1' %>
    <% end %>
  </div>
</div>

<!-- Add style to ensure link fills cell -->
<style>
  .cell-link {
    min-width: 40px;
    min-height: 40px;
    display: block;
    width: 100%;
    height: 100%;
    background: #eee;
    margin: 0;
    padding: 0;
  }
</style>
