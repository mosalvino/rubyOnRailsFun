<div class="container center-align" style="margin-top: 40px;">
  <h1 class="teal-text">Tic Tac Toe</h1>
  <table class="striped centered" style="margin: 0 auto;">
    <% @game.board_array.each_with_index do |row, i| %>
      <tr>
        <% row.each_with_index do |cell, j| %>
          <td style="width:40px;height:40px;text-align:center;border:1px solid #000; padding:0;">
            <span style="display:block;width:100%;height:100%;background:#80cbc4;border-radius:4px;"> <%= cell %> </span>
          </td>
        <% end %>
      </tr>
    <% end %>
  </table>
  <p class="flow-text">Current Player: <span class="badge teal white-text"> <%= @game.current_player %> </span></p>
  <p class="flow-text">Status: <span class="badge grey lighten-1 white-text"> <%= @game.status %> </span></p>
  <div style="margin-top: 20px;">
    <div style="margin-bottom: 10px;">
      <label for="player_select">Choose your symbol:</label>
      <select id="player_select" name="player_select" onchange="updateFriendLink()">
        <option value="X">X</option>
        <option value="O">O</option>
      </select>
    </div>
    <%= link_to 'Play vs Friend', games_play_path(mode: 'friend', player: 'X'), id: 'play-friend-btn', class: 'btn-large teal lighten-1' %>
    <%= link_to 'Play vs CPU', games_play_path(mode: 'single'), class: 'btn-large blue lighten-1' %>
    <script>
      function updateFriendLink() {
        var select = document.getElementById('player_select');
        var btn = document.getElementById('play-friend-btn');
        var player = select.value;
        btn.href = '/games/play?mode=friend&player=' + player;
      }
    </script>
    <%= link_to 'Reset', games_reset_path, class: 'btn-large red lighten-1' %>
  </div>
</div>
